# ── Banco de dados ────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgresql://pac_user:SENHA_AQUI@localhost:5432/pac_control

# Se o PostgreSQL exigir SSL (ex: Neon), mude para true
DATABASE_SSL=false

# ── Sessão ────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
SESSION_SECRET=TROQUE_POR_UMA_STRING_ALEATORIA_LONGA

# ── Agente desktop ────────────────────────────────────────────────────────────
# Token que o agente usa para se autenticar nas APIs
# Gere com: openssl rand -hex 24
AGENT_BOOTSTRAP_TOKEN=TROQUE_POR_TOKEN_SEGURO
# Pasta local para armazenar screenshots enviados pelo agente
SCREENSHOTS_DIR=/tmp/pac-control-screenshots

# ── Cron / API interna ────────────────────────────────────────────────────────
# Token para o job de rollup diário
# Gere com: openssl rand -hex 24
DASHBOARD_API_TOKEN=TROQUE_POR_TOKEN_SEGURO

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=PAC CONTROL

# ── Apenas desenvolvimento local ──────────────────────────────────────────────
# NÃO colocar em produção
# DEMO_MODE=true
